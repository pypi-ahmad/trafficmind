TRAFFICMIND_ENV=local
TRAFFICMIND_STRICT_STARTUP_CHECKS=false
LOG_LEVEL=INFO
TRAFFICMIND_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MODEL_DIR=./models
YOLO_MODEL_PATH=./models/yolo26x.pt

# ── GPU / device behaviour ──────────────────────────────────────────────
# Vision (PyTorch / YOLO):
#   VISION_DEVICE=auto    → picks CUDA when torch.cuda.is_available(), else CPU
#   VISION_DEVICE=cuda    → force GPU (fails at inference if no CUDA)
#   VISION_DEVICE=cpu     → force CPU even when GPU is present
VISION_DEVICE=auto
VISION_HALF_PRECISION=true

# OCR (PaddlePaddle / PaddleOCR):
#   OCR_USE_GPU=true + no OCR_DEVICE → auto-detect via Paddle runtime:
#     • paddlepaddle-gpu installed (Linux) → gpu:0
#     • paddlepaddle CPU-only (Windows)    → cpu (with warning)
#   OCR_DEVICE=gpu:0      → force Paddle GPU
#   OCR_DEVICE=cpu         → force Paddle CPU
#   OCR_USE_GPU=false      → force CPU unconditionally
OCR_USE_GPU=true
# OCR_DEVICE=
DATABASE_URL=sqlite+aiosqlite:///./trafficmind.db
REDIS_URL=redis://localhost:6379/0
API_PORT=8000
WORKFLOW_PORT=8010
WEB_PORT=3000
TRAFFICMIND_API_BASE_URL=http://127.0.0.1:8000/api/v1
NEXT_PUBLIC_TRAFFICMIND_API_BASE_URL=http://127.0.0.1:8000/api/v1
TRAFFICMIND_WORKFLOW_BASE_URL=http://127.0.0.1:8010/api/v1
TRAFFICMIND_FRONTEND_BASE_URL=http://127.0.0.1:3000
TRAFFICMIND_EVALUATION_FIXTURE_SUITE_PATH=./tests/fixtures/evaluation/benchmark_suite.json
TRAFFICMIND_EVALUATION_ARTIFACT_DIR=./outputs/evaluation
WORKFLOW_PROVIDER_BACKEND=heuristic
WORKFLOW_CHECKPOINT_BACKEND=memory

# ── Alert delivery (SMTP defaults for email adapter) ────────────────────
# Per-target target_config overrides these if set.
# ALERT_SMTP_HOST=
# ALERT_SMTP_PORT=587
# ALERT_SMTP_USER=
# ALERT_SMTP_PASS=
# ALERT_SMTP_FROM=noreply@trafficmind.local

TRAFFICMIND_SPATIAL_LOOKBACK_DAYS=7
TRAFFICMIND_SPATIAL_TOP_N=48
NEXT_PUBLIC_MAP_PROVIDER=coordinate-grid
NEXT_PUBLIC_MAP_STYLE_URL=
NEXT_PUBLIC_MAP_ACCESS_TOKEN=
OPENAI_API_KEY=
