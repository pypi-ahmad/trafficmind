# API service — minimal override example.
# Canonical source of all variables: <repo-root>/.env.example
# Copy the root .env.example to .env for a complete local setup;
# this file lists only the subset the API service reads directly.

APP_NAME=TrafficMind API
TRAFFICMIND_ENV=local
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./trafficmind.db
REDIS_URL=redis://localhost:6379/0
MODEL_DIR=./models
YOLO_MODEL_PATH=./models/yolo26x.pt
