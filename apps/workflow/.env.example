# Workflow service — minimal override example.
# Canonical source of all variables: <repo-root>/.env.example
# Copy the root .env.example to .env for a complete local setup;
# this file lists only the subset the workflow service reads directly.

APP_NAME=TrafficMind Workflow
TRAFFICMIND_ENV=local
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8010
DATABASE_URL=sqlite+aiosqlite:///./trafficmind.db
WORKFLOW_PROVIDER_BACKEND=heuristic
WORKFLOW_CHECKPOINT_BACKEND=memory
OPENAI_API_KEY=
LANGSMITH_API_KEY=
