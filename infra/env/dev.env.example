TRAFFICMIND_ENV=dev
TRAFFICMIND_STRICT_STARTUP_CHECKS=false
LOG_LEVEL=INFO

DATABASE_URL=sqlite+aiosqlite:///./trafficmind.db
REDIS_URL=redis://localhost:6379/0

TRAFFICMIND_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_PORT=8000
WORKFLOW_PORT=8010
WEB_PORT=3000

TRAFFICMIND_API_BASE_URL=http://127.0.0.1:8000/api/v1
NEXT_PUBLIC_TRAFFICMIND_API_BASE_URL=http://127.0.0.1:8000/api/v1
TRAFFICMIND_WORKFLOW_BASE_URL=http://127.0.0.1:8010/api/v1
TRAFFICMIND_FRONTEND_BASE_URL=http://127.0.0.1:3000

MODEL_DIR=./models
YOLO_MODEL_PATH=./models/yolo26x.pt
VISION_DEVICE=auto
VISION_HALF_PRECISION=true
OCR_USE_GPU=true

TRAFFICMIND_EVALUATION_FIXTURE_SUITE_PATH=./tests/fixtures/evaluation/benchmark_suite.json
TRAFFICMIND_EVALUATION_ARTIFACT_DIR=./outputs/evaluation

WORKFLOW_PROVIDER_BACKEND=heuristic
WORKFLOW_CHECKPOINT_BACKEND=memory
OPENAI_API_KEY=

TRAFFICMIND_SPATIAL_LOOKBACK_DAYS=7
TRAFFICMIND_SPATIAL_TOP_N=48
NEXT_PUBLIC_MAP_PROVIDER=coordinate-grid
NEXT_PUBLIC_MAP_STYLE_URL=
NEXT_PUBLIC_MAP_ACCESS_TOKEN=