TRAFFICMIND_ENV=prod
TRAFFICMIND_STRICT_STARTUP_CHECKS=true
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://trafficmind:change-me@db-host:5432/trafficmind
REDIS_URL=redis://redis-host:6379/0

TRAFFICMIND_ALLOWED_ORIGINS=https://trafficmind.example.com
API_PORT=8000
WORKFLOW_PORT=8010
WEB_PORT=3000

TRAFFICMIND_API_BASE_URL=https://api.trafficmind.example.com/api/v1
NEXT_PUBLIC_TRAFFICMIND_API_BASE_URL=https://api.trafficmind.example.com/api/v1
TRAFFICMIND_WORKFLOW_BASE_URL=https://workflow.trafficmind.example.com/api/v1
TRAFFICMIND_FRONTEND_BASE_URL=https://trafficmind.example.com

MODEL_DIR=/srv/trafficmind/models
YOLO_MODEL_PATH=/srv/trafficmind/models/yolo26x.pt
VISION_DEVICE=cpu
VISION_HALF_PRECISION=false
OCR_USE_GPU=false

TRAFFICMIND_EVALUATION_FIXTURE_SUITE_PATH=./tests/fixtures/evaluation/benchmark_suite.json
TRAFFICMIND_EVALUATION_ARTIFACT_DIR=./outputs/evaluation

# The workflow service still only supports the deterministic heuristic backend.
WORKFLOW_PROVIDER_BACKEND=heuristic

# This remains intentionally honest: readiness will report that memory checkpoints
# are not production-grade yet.
WORKFLOW_CHECKPOINT_BACKEND=memory
OPENAI_API_KEY=

TRAFFICMIND_SPATIAL_LOOKBACK_DAYS=7
TRAFFICMIND_SPATIAL_TOP_N=48
NEXT_PUBLIC_MAP_PROVIDER=coordinate-grid
NEXT_PUBLIC_MAP_STYLE_URL=
NEXT_PUBLIC_MAP_ACCESS_TOKEN=